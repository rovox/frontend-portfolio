---
---

<section class="section hero" id="home">
  <div class="container">
    <!-- <span class="pill">System.init(...)</span> -->
    <h1 class="hero-title">Jose Roberto Vargas Orellana</h1>
    <p class="subtitle">&gt; Computer Engineer &amp; UI/UX Designer</p>
    <div class="hero-actions">
      <a class="btn" href="#projects">View Projects</a>
      <a class="btn" href="#">Download CV</a>
      <a class="btn" href="#contact">Contact Me</a>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const startHeroAnimation = () => {
    gsap.fromTo(
      '.hero-title',
      { opacity: 0, y: 40, filter: 'blur(8px)' },
      { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1.5, ease: 'power3.out', delay: 0.3 }
    );

    gsap.fromTo(
      '.subtitle',
      { opacity: 0, y: 20, filter: 'blur(6px)' },
      { opacity: 1, y: 0, filter: 'blur(0px)', duration: 1.2, ease: 'power3.out', delay: 0.6 }
    );

    gsap.fromTo(
      '.hero-actions',
      { opacity: 0, y: 15 },
      { opacity: 1, y: 0, duration: 1, ease: 'power3.out', delay: 0.9 }
    );

    gsap.fromTo(
      '.pill',
      { opacity: 0, scale: 0.8 },
      { opacity: 1, scale: 1, duration: 0.8, ease: 'back.out(1.7)', delay: 0.1 }
    );
  };

  if (window.__portfolioLoaderDone) {
    startHeroAnimation();
  } else {
    window.addEventListener('preloader:done', startHeroAnimation, { once: true });
  }
</script>

<style>
  .hero {
    text-align: center;
  }

  .pill {
    display: inline-block;
    padding: 0.5rem 0.85rem;
    margin-bottom: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .hero-title {
    font-size: clamp(2.2rem, 7vw, 4.8rem);
    line-height: 1.08;
    margin: 0;
    font-family: var(--font-mono);
    text-shadow: 0 0 25px rgba(45, 226, 230, 0.22);
    opacity: 0;
  }

  .subtitle {
    margin-top: 1rem;
    font-size: clamp(1.1rem, 3.3vw, 1.6rem);
    color: var(--muted);
    font-family: var(--font-mono);
    opacity: 0;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    opacity: 0;
  }
</style>
