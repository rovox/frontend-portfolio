---
import DynamicBackground from '../components/DynamicBackground.tsx';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Jose Roberto Vargas Orellana — Computer Engineer & UI/UX Designer. Immersive portfolio." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <DynamicBackground client:only="react" />
    <Navbar />
    <div class="page">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #04070f;
    --surface: rgba(17, 25, 40, 0.55);
    --surface-strong: rgba(10, 16, 28, 0.9);
    --border: rgba(76, 97, 132, 0.45);
    --text: #e9f0ff;
    --muted: #9eb1d4;
    --primary: #2de2e6;
    --secondary: #55ff9f;
    --accent: #8f6bff;
    --font-body: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, monospace;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    scroll-behavior: smooth;
    font-family: var(--font-body);
    background: radial-gradient(circle at 20% 10%, #14233d 0%, var(--bg) 50%);
    color: var(--text);
    overflow-x: hidden;
    padding-top: 70px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page {
    position: relative;
  }

  .section {
    min-height: 100vh;
    padding: 5rem 1.25rem;
    display: flex;
    align-items: center;
    position: relative;
  }

  .container {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .section-title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.8rem, 4.8vw, 3rem);
    font-family: var(--font-mono);
  }

  .section-note {
    margin: 0 0 2rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .btn {
    display: inline-block;
    padding: 0.7rem 1.1rem;
    border-radius: 0.6rem;
    font-weight: 600;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
    border-color: rgba(45, 226, 230, 0.7);
    box-shadow: 0 0 24px rgba(45, 226, 230, 0.2);
  }
</style>
